 "cells": [
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "# Phase 3: Face Recognition Pipeline with InsightFace\n",
    "Notebook ini mendemonstrasikan tahapan dalam pipeline *Face Recognition* menggunakan InsightFace:\n",
    "1. **Detection:** Deteksi wajah menggunakan SCRFD.\n",
    "2. **Alignment:** Estimasi *landmarks* 2D.\n",
    "3. **Embedding:** Ekstraksi fitur (512-dimensi) menggunakan model ArcFace.\n",
    "4. **Matching:** Pencocokan identitas dengan *Cosine Similarity*."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "import sys\n",
    "import os\n",
    "from pathlib import Path\n",
    "import cv2\n",
    "import numpy as np\n",
    "import matplotlib.pyplot as plt\n",
    "\n",
    "project_root = str(Path(os.getcwd()).parent)\n",
    "if project_root not in sys.path:\n",
    "    sys.path.append(project_root)\n",
    "\n",
    "from backend.app.models.face_engine import FaceEngine\n",
    "\n",
    "def show_img(img_bgr, title=\"Image\"):\n",
    "    plt.figure(figsize=(8, 6))\n",
    "    plt.imshow(cv2.cvtColor(img_bgr, cv2.COLOR_BGR2RGB))\n",
    "    plt.title(title)\n",
    "    plt.axis('off')\n",
    "    plt.show()"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Inisialisasi Face Engine"
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "# Inisialisasi InsightFace (menggunakan model 'buffalo_l')\n",
    "engine = FaceEngine.get_instance()\n",
    "engine.initialize(ctx_id=0) # ctx_id=0 untuk GPU, -1 untuk CPU"
   ]
  },
  {
   "cell_type": "markdown",
   "metadata": {},
   "source": [
    "### Deteksi Wajah dan Ekstraksi Fitur\n",
    "Silakan tempatkan sebuah gambar di `data/sample_face.jpg` untuk menjalankan blok ini."
   ]
  },
  {
   "cell_type": "code",
   "execution_count": null,
   "metadata": {},
   "outputs": [],
   "source": [
    "sample_img_path = os.path.join(project_root, 'data', 'sample_face.jpg')\n",
    "\n",
    "if os.path.exists(sample_img_path):\n",
    "    img = cv2.imread(sample_img_path)\n",
    "    faces = engine.detect_faces(img)\n",
    "    \n",
    "    img_draw = img.copy()\n",
    "    for face in faces:\n",
    "        bbox = face['bbox']\n",
    "        cv2.rectangle(img_draw, (int(bbox[0]), int(bbox[1])), (int(bbox[2]), int(bbox[3])), (0, 255, 0), 2)\n",
    "        \n",
    "        # Draw landmarks\n",
    "        if face['landmarks']:\n",
    "            for pt in face['landmarks']:\n",
    "                cv2.circle(img_draw, (int(pt[0]), int(pt[1])), 2, (0, 0, 255), -1)\n",
    "                \n",
    "    show_img(img_draw, f\"Detected {len(faces)} face(s)\")\n",
    "    \n",
    "    if len(faces) > 0:\n",
    "        print(f\"Embedding shape: {faces[0]['embedding'].shape}\")\n",
    "else:\n",
    "    print(f\"File not found: {sample_img_path}. Please add a test image.\")"
   ]
  }
 ],
